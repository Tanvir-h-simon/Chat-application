# Copy this file to ".env" and fill in the values.

# App
APP_NAME=Ping
NODE_ENV=development
PORT=3000

# Database — a MongoDB connection string (local, or from MongoDB Atlas)
MONGO_URI=

# Secrets — use long random strings, at least 32 characters each
COOKIE_SECRET=
JWT_SECRET=

# First admin account, created by: npm run seed:admin
ADMIN_NAME=
ADMIN_AGE=
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_MOBILE=
