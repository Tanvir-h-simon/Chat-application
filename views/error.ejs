<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="shortcut icon" href="/images/favicon.png" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/inter@5.0.16/400.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/inter@5.0.16/700.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.5.0/dist/tabler-icons.min.css" />
    <link rel="stylesheet" href="/stylesheets/style.css" />
    <style>
      .error-page { min-height: 100vh; display: flex; flex-direction: column;
        align-items: center; justify-content: center; text-align: center; padding: 24px; }
      .error-page .glyph { width: 92px; height: 92px; border-radius: 24px;
        background: var(--accent-soft); color: var(--accent);
        display: flex; align-items: center; justify-content: center;
        font-size: 46px; margin-bottom: 22px; }
      .error-page h1 { font-size: 52px; font-weight: 700; color: var(--text); }
      .error-page p { color: var(--text-muted); font-size: 16px; margin: 8px 0 24px; }
      .error-page a { background: var(--accent); color: var(--accent-ink);
        text-decoration: none; font-weight: 600; padding: 12px 22px;
        border-radius: var(--radius); display: inline-flex; align-items: center; gap: 8px; }
      .error-page a:hover { background: var(--accent-hover); }
    </style>
  </head>
  <body>
    <div class="error-page">
      <div class="glyph"><i class="ti ti-message-off"></i></div>
      <h1><%= status || 500 %></h1>
      <p><%= message %></p>
      <a href="/inbox"><i class="ti ti-arrow-left"></i> Back to inbox</a>
    </div>
  </body>
</html>
