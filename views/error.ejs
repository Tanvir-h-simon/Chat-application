<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
</head>
<body>
    <h1><%= error.status || 500 %></h1>
    <p><%= error.message %></p>
    <% if (error.stack) { %>
        <pre><%= error.stack %></pre>
    <% } %>
</body>
</html>
