<%- include('./partials/header.ejs', { fullBleed: true }); %>
    <div id="login-container">
      <div id="branding">
        <svg width="60" height="60" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Ping logo">
          <rect width="48" height="48" rx="13" fill="#4CAF50"/>
          <path d="M14 16.5C14 14.567 15.567 13 17.5 13H30.5C32.433 13 34 14.567 34 16.5V25.5C34 27.433 32.433 29 30.5 29H22L16.5 33.5V29H17.5C15.567 29 14 27.433 14 25.5V16.5Z" fill="#0a1014"/>
          <circle cx="20" cy="21" r="1.9" fill="#4CAF50"/>
          <circle cx="24" cy="21" r="1.9" fill="#4CAF50"/>
          <circle cx="28" cy="21" r="1.9" fill="#4CAF50"/>
        </svg>
        <h1>Welcome to Ping<span style="color:#4CAF50">.</span></h1>
      </div>
      <div id="login-form">
        <form method="post" action="/">
          <input
            type="text"
            name="username"
            placeholder="Enter mobile or email"
            value="<%= locals.data ? data.username : '' %>"
          />
          <% if (locals.errors && errors.username) { %>
            <p class="error show"><%= errors.username.msg %></p>
          <% } %>
          <input type="password" name="password" placeholder="Enter password" />
          <% if (locals.errors && errors.password) { %>
            <p class="error show"><%= errors.password.msg %></p>
          <% } %>
          <% if (locals.errors && errors.general) { %>
            <p class="error show"><%= errors.general.msg %></p>
          <% } %>
          <input type="submit" value="Login" />
        </form>
      </div>
    </div>
  </body>
</html>
