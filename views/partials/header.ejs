<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="author" content="Tanvir Hossain" />
    <title><%= title %></title>
    <link rel="shortcut icon" href="/images/favicon.png" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/inter@5.0.16/400.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/inter@5.0.16/500.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/inter@5.0.16/600.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/inter@5.0.16/700.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.5.0/dist/tabler-icons.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.css" />
    <link rel="stylesheet" href="/stylesheets/style.css" />
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
  </head>
  <body>
    <% if (!locals.fullBleed) { %>
    <header class="topbar">
      <a href="/inbox" class="brand">
        <svg class="logo" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Ping logo">
          <rect width="48" height="48" rx="13" fill="#4CAF50"/>
          <path d="M14 16.5C14 14.567 15.567 13 17.5 13H30.5C32.433 13 34 14.567 34 16.5V25.5C34 27.433 32.433 29 30.5 29H22L16.5 33.5V29H17.5C15.567 29 14 27.433 14 25.5V16.5Z" fill="#0a1014"/>
          <circle cx="20" cy="21" r="1.9" fill="#4CAF50"/>
          <circle cx="24" cy="21" r="1.9" fill="#4CAF50"/>
          <circle cx="28" cy="21" r="1.9" fill="#4CAF50"/>
        </svg>
        <span class="wordmark">Ping<span class="dot">.</span></span>
      </a>
      <nav class="topnav">
        <a href="/inbox" class="<%= locals.active === 'inbox' ? 'active' : '' %>">Inbox</a>
        <% if (locals.user && locals.user.role === 'admin') { %>
        <a href="/users" class="<%= locals.active === 'users' ? 'active' : '' %>">Users</a>
        <% } %>
        <% if (locals.isLoggedIn) { %>
        <a href="/profile" class="<%= locals.active === 'profile' ? 'active' : '' %>">Profile</a>
        <% } %>
      </nav>
      <% if (locals.isLoggedIn) { %>
      <a href="/logout" class="icon-btn" title="Logout" aria-label="Logout"><i class="ti ti-logout"></i></a>
      <% } else { %>
      <a href="/" class="topnav"><span style="padding:8px 14px">Login</span></a>
      <% } %>
    </header>
    <% } %>
    <% if (locals.flash) { %>
    <script>
      Toastify({
        text: "<%= flash %>",
        duration: 3000,
        gravity: "top",
        position: "right",
        style: { background: "#4CAF50" },
      }).showToast();
    </script>
    <% } %>
